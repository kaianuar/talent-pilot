# Pre-commit: fast checks for both frontend and backend
# Runs on staged files only, should complete in ~30s

set -e
ROOT="$(git rev-parse --show-toplevel)"

echo "🔍 Running pre-commit checks..."

# Frontend: oxlint (fast, catches type issues and code smells)
echo "  → frontend: oxlint"
cd "$ROOT/frontend-react" && npx oxlint --quiet

# Backend: check staged Python files compile
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
  echo "  → backend: checking Python syntax"
  for file in $STAGED_PY; do
    python3 -m py_compile "$ROOT/$file" 2>/dev/null || {
      echo "❌ Python syntax error in $file"
      exit 1
    }
  done
fi

# Backend: run full test suite
echo "  → backend: pytest"
cd "$ROOT"
TEST_RAN=0
for ver in 3.12 3.11 3.13; do
  PYBIN="$HOME/.pyenv/versions/${ver}.*/bin/python"
  PYBIN=$(ls $PYBIN 2>/dev/null | head -1)
  if [ -n "$PYBIN" ] && "$PYBIN" -c "import pytest" 2>/dev/null; then
    "$PYBIN" -m pytest tests/ -x --tb=short -q && TEST_RAN=1
    break
  fi
done
if [ "$TEST_RAN" -eq 0 ]; then
  for py in python python3; do
    if command -v "$py" >/dev/null 2>&1 && "$py" -c "import pytest" 2>/dev/null; then
      "$py" -m pytest tests/ -x --tb=short -q && TEST_RAN=1
      break
    fi
  done
fi
if [ "$TEST_RAN" -eq 0 ]; then
  echo "❌ pytest not found. Install with: pip install pytest"
  exit 1
fi

echo "✅ Pre-commit checks passed"
