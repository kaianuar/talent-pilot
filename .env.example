# Environment Variables - Copy to .env and fill in values
# This file is the SINGLE source of truth for env var names used in this repo.
# Container deployment uses these via -e flags or Function Compute env vars.

# --- Qwen Cloud API ---
QWEN_API_KEY=your-qwen-cloud-api-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Models (defaults shown) ---
# MODEL_REASONING is used for matching, screening questions, and email drafting.
MODEL_REASONING=qwen3-max
# MODEL_VISION is used as the fallback for scanned-PDF resume parsing.
MODEL_VISION=qwen3-vl-plus
# MODEL_CHAT is used for text-extractable resume parsing (primary path).
MODEL_CHAT=qwen-turbo

# --- Alibaba DirectMail SMTP (for /applications email send) ---
ALIYUN_SMTP_USER=your-smtp-user
ALIYUN_SMTP_PASS=your-smtp-password
SMTP_SENDER=noreply@yourdomain.com

# --- Backend server ---
API_HOST=0.0.0.0
# Internal port — bound inside the container by uvicorn.
API_PORT=8000
# External port — bound by nginx, exposed by the container.
EXPOSE_PORT=9000

# --- Frontend ---
# In dev: Vite proxy on http://localhost:9000
# In prod: leave blank so axios uses same-origin (the React app is served
# from the same host as the API, so all /upload /match etc. calls are
# same-origin and don't need CORS or an absolute URL).
VITE_API_URL=

# --- Deployment metadata ---
DEPLOY_REGION=ap-southeast-1
ACR_REGISTRY=registry.ap-southeast-1.cr.aliyuncs.com
ACR_NAMESPACE=talentpilot
